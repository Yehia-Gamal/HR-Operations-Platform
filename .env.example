# Sample environment configuration for Supabase Edge Functions
#
# ملاحظة: هذه النسخة من التطبيق لا تحتاج إلى ملف .env لتشغيل الواجهة.
# القيم التالية تُستخدم في Edge Functions وخدمات الخلفية فقط،
# ولا يجب تضمينها في ملفات الواجهة العامة أو في Git.

# Supabase connection configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Origins allowed to call Edge Functions (comma‑separated)
ALLOWED_ORIGINS=
SITE_URL=

# WebAuthn support (set to true when server verification is enabled)
WEBAUTHN_ENABLED=false

# Phone login rate limiting
LOGIN_RATE_LIMIT_SALT=
LOGIN_RESOLVE_MAX_ATTEMPTS=8
LOGIN_RESOLVE_BLOCK_MINUTES=15

# Web Push / VAPID configuration for send-push-notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.example

# Additional secrets (not used by frontend)
APP_VAULT_KEY=