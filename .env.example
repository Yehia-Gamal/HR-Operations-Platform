# Supabase Edge Functions تستخدم هذه المتغيرات داخل Supabase نفسه:
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# لا تضع SERVICE_ROLE_KEY داخل الواجهة أو GitHub أبدًا.

# Supabase Edge Functions
# Comma-separated allowed origins for Edge Function CORS, e.g. https://hr.example.com,http://localhost:5500
ALLOWED_ORIGINS=
SITE_URL=
# Keep false until full @simplewebauthn/server challenge verification is deployed.
WEBAUTHN_ENABLED=false

# Phone-login resolver rate limiting
LOGIN_RATE_LIMIT_SALT=
LOGIN_RESOLVE_MAX_ATTEMPTS=8
LOGIN_RESOLVE_BLOCK_MINUTES=15
